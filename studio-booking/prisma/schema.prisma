generator client {
  provider      = "prisma-client-js"
  // Windows-Build + ZIP-Deploy auf Linux (Plesk): Engines für gängige Server mit einpacken.
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum BookingType {
  PROBETRAINING
  PERSONAL_TRAINING
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  DONE
  ARCHIVED
}

enum ContactCategory {
  GENERAL
  MEMBERSHIP
  OTHER
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Ein buchbarer Zeitslot (vom Betreiber freigegeben). Max. eine aktive Buchung pro Slot.
model TimeSlot {
  id          String      @id @default(cuid())
  startAt     DateTime
  endAt       DateTime
  bookingType BookingType
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  booking     Booking?

  @@index([bookingType, startAt])
  @@index([startAt])
}

model Booking {
  id        String        @id @default(cuid())
  slotId    String        @unique
  slot      TimeSlot      @relation(fields: [slotId], references: [id], onDelete: Cascade)
  type      BookingType
  firstName String
  lastName  String
  email     String
  phone     String
  notes     String? @db.Text
  status    BookingStatus @default(CONFIRMED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([type, status, createdAt])
  @@index([email])
}

model ContactInquiry {
  id        String          @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String
  subject   String   @db.VarChar(500)
  message   String   @db.Text
  category  ContactCategory @default(GENERAL)
  status    ContactStatus   @default(NEW)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([status, createdAt])
}
