# MariaDB / MySQL (z. B. Plesk, eigener Server). Port meist 3306.
# SSL: je nach Hoster ?sslaccept=strict oder ohne Zusatz bei localhost
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"

# NextAuth / Auth.js — z. B. openssl rand -base64 32
AUTH_SECRET="mindestens-32-zeichen-zufaellig"

# Öffentliche URL dieser Next.js-App (ohne trailing slash). Immer Schema angeben:
#   http://localhost:3001  oder  https://buchung.ladyfitness-bremgarten.ch
# Ohne https:// wird automatisch https:// ergänzt (nur für Tippfehler-Toleranz).
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Logo für E-Mails (optional, Standard: ladyfitness-bremgarten.ch)
# NEXT_PUBLIC_BRAND_LOGO_URL="https://ladyfitness-bremgarten.ch/images/logo.png"

# Resend (https://resend.com) — Domain im Resend-Dashboard verifizieren
RESEND_API_KEY="re_xxxxxxxx"

# Absender (verifizierte Domain bei Resend)
MAIL_FROM="Lady Fitness Bremgarten <buchung@ladyfitness-bremgarten.ch>"

# Benachrichtigungen an Studio / Inhaberin
OPERATOR_EMAIL="info@ladyfitness-bremgarten.ch"

# Einmalig für prisma db seed — Admin-Zugang anlegen (nach Änderung: npm run db:seed)
# ADMIN_SEED_EMAIL="admin@ihre-domain.ch"
# ADMIN_SEED_PASSWORD="starkes-passwort"
# Diagnose: npm run db:verify-admin
