# ============================================================
# Lady Fitness Bremgarten – Buchungs-App (.env.example)
# Diese Datei als .env kopieren und Werte eintragen.
# ============================================================

# ------------------------------------------------------------------
# Supabase (https://app.supabase.com → Settings → API)
# ------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
SUPABASE_SERVICE_KEY="sb_secret_..."

# ------------------------------------------------------------------
# NextAuth / Auth.js (Admin-Login)
# Generieren: openssl rand -base64 32
# ------------------------------------------------------------------
AUTH_SECRET="mindestens-32-zeichen-zufaellig"

# ------------------------------------------------------------------
# Öffentliche URL dieser App (ohne trailing slash)
# Lokal: http://localhost:3001
# Produktion: https://ladyfitness-bremgarten.ch
# ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# ------------------------------------------------------------------
# Resend (https://resend.com) – für Buchungs- und Kontakt-E-Mails
# ------------------------------------------------------------------
RESEND_API_KEY="re_xxxxxxxx"
MAIL_FROM="Lady Fitness Bremgarten <buchung@ladyfitness-bremgarten.ch>"
OPERATOR_EMAIL="buchung@ladyfitness-bremgarten.ch"

# ------------------------------------------------------------------
# Logo für E-Mails (optional)
# ------------------------------------------------------------------
# NEXT_PUBLIC_BRAND_LOGO_URL="https://ladyfitness-bremgarten.ch/images/logo.png"

# ------------------------------------------------------------------
# Admin-Seed (nur einmalig für: npm run db:seed-admin)
# Nach dem Anlegen: Zeilen auskommentieren oder entfernen
# ------------------------------------------------------------------
# ADMIN_SEED_EMAIL="admin@ladyfitness-bremgarten.ch"
# ADMIN_SEED_PASSWORD="starkes-passwort-hier"
# ADMIN_SEED_NAME="Inhaberin"
