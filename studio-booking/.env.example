# Kopie als .env — keine echten Secrets ins Repo.

NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_KEY="sb_secret_ersetzen"
# Optional (aktuell nutzt der Server nur den Service-Key):
# NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_ersetzen"

AUTH_SECRET="mindestens-32-zeichen-zufaellig-generieren"

NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Optional: Standalone-Start (npm start) — Standard Next ist 3000
# PORT=3001

RESEND_API_KEY="re_ersetzen"
MAIL_FROM="Lady Fitness Bremgarten <buchung@ladyfitness-bremgarten.ch>"
OPERATOR_EMAIL="buchung@ladyfitness-bremgarten.ch"

# Optional
# NEXT_PUBLIC_BRAND_LOGO_URL="https://example.ch/images/logo.png"

# Einmalig für npm run db:seed-admin — danach entfernen
# ADMIN_SEED_EMAIL="admin@example.ch"
# ADMIN_SEED_PASSWORD="ersetzen"
# ADMIN_SEED_NAME="Admin"
